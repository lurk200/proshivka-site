# Пароль входа в админку (/admin/login)
VITE_ADMIN_PASSWORD=смените_на_сильный_пароль

# URL сайта (используется в ссылках уведомлений вместо localhost).
# Укажите полный адрес: https://proshivka-stv.ru
# VITE_SITE_URL=https://proshivka-stv.ru

# Папка CMS на сервере (не в git, не удаляется при git pull).
# PM2 задаёт автоматически: ../proshivka-data/cms относительно проекта.
# CMS_DATA_DIR=/home/user/proshivka-data/cms

# Webhook для уведомлений при изменении статуса заказа.
# POST-запрос с JSON-телом будет отправлен на этот URL.
# VITE_NOTIFY_WEBHOOK_URL=https://hooks.example.com/proshivka
